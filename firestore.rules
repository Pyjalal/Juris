rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------

    // Returns true if the request originates from an authenticated user.
    function isAuthenticated() {
      return request.auth != null;
    }

    // Returns true if the authenticated user's UID matches the provided uid.
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Returns true if the authenticated user carries the "admin" custom claim.
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ---------------------------------------------------------------
    // documents collection
    // Users can read and write only their own documents.
    // Admins and Cloud Functions (via Admin SDK) bypass these rules.
    // ---------------------------------------------------------------
    match /documents/{docId} {
      allow read:  if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // audits collection
    // Users can read their own audits (created by Cloud Functions).
    // Only Cloud Functions (Admin SDK) or admins can write.
    // ---------------------------------------------------------------
    match /audits/{auditId} {
      allow read:  if isOwner(resource.data.uid) || isAdmin();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // law_chunks collection
    // Public read access for all authenticated users.
    // Only Cloud Functions (Admin SDK) or admins can write.
    // ---------------------------------------------------------------
    match /law_chunks/{chunkId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------------
    // letters_of_demand collection
    // Users can read and write their own letters of demand.
    // Admins can read and write all.
    // ---------------------------------------------------------------
    match /letters_of_demand/{lodId} {
      allow read:  if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------------
    // Default: deny all unmatched paths
    // ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
